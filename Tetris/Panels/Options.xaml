<UserControl x:Class="Tetris.Panels.Options"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Tetris.Panels"
             xmlns:base="clr-namespace:Tetris.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Grid.Column="1" BorderBrush="{DynamicResource TetrisPurple}" CornerRadius="20" BorderThickness="2" Width="180" Height="120">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource PanelLightBackground}"/>

                <Style.Triggers>
                    <DataTrigger
    Binding="{Binding DarkMode,
                      RelativeSource={RelativeSource AncestorType=local:Options}}"
    Value="True">
                        <Setter Property="Background" Value="{DynamicResource PanelDarkBackground}"/>
                    </DataTrigger>
                </Style.Triggers>

            </Style>
        </Border.Style>

        <StackPanel Orientation="Vertical">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,10,0,0">
                <Image Source="/Images/Icons/Options.png" Width="32" Height="32"></Image>
                <TextBlock VerticalAlignment="Center" x:Name="optionsTitle" Text="OPTIONS" Margin="5,0,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <base:GameCheckBox
                x:Name="cbTheme"
 Margin="10,0,0,0"
            Width="45"
            Height="45"
                    BackColorOn="Black"
                    BackColorOff="White"
                    IconOn="/Images/Icons/Moon.png"
                    IconOff="/Images/Icons/Sun.png"
                    Checked="cbTheme_Checked"
                    Unchecked="cbTheme_Unchecked"
                    
                    
/>
                <base:GameCheckBox
                x:Name="cbSound"
 Margin="10,0,0,0"
            Width="45"
            Height="45"
                     BackColorOn="Black"
 BackColorOff="White"
 IconOn="/Images/Icons/SoundOff.png"
 IconOff="/Images/Icons/SoundOn.png"
                    Checked="cbSound_Checked"
                    Unchecked="cbSound_Unchecked"
/>
                <base:GameCheckBox
                x:Name="cbLanguage"
 Margin="10,0,0,0"
            Width="45"
            Height="45"
                                        BackColorOn="Black"
BackColorOff="White"
IconOn="/Images/Icons/PersianLan.png"
IconOff="/Images/Icons/EnglishLan.png"
                    Checked="cbLanguage_Checked"
                    Unchecked="cbLanguage_Unchecked"
/>
            </StackPanel>
        </StackPanel>
        
    </Border>
</UserControl>
