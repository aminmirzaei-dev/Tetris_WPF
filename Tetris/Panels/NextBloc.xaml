<UserControl x:Class="Tetris.Panels.NextBloc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Tetris.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="20" Height="200" Width="180" BorderBrush="{DynamicResource TetrisBlue}" BorderThickness="2">

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource PanelLightBackground}"/>

                <Style.Triggers>
                    <DataTrigger
        Binding="{Binding DarkMode,
                          RelativeSource={RelativeSource AncestorType=local:NextBloc}}"
        Value="True">
                        <Setter Property="Background" Value="{DynamicResource PanelDarkBackground}"/>
                    </DataTrigger>
                </Style.Triggers>

            </Style>
        </Border.Style>
        
        
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,10,0,0">
                <Image Source="/Images/Icons/Next.png" Width="32" Height="32"></Image>
                <TextBlock VerticalAlignment="Center" Text="NEXT" Margin="5,0,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
            </StackPanel>
            <Canvas x:Name="nextShapeCanvas" x:FieldModifier="private" HorizontalAlignment="Left" Height="80" Margin="344,94,0,0" VerticalAlignment="Top" Width="100"/>
        </StackPanel>
    </Border>
</UserControl>
