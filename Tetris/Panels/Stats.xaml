<UserControl x:Class="Tetris.Panels.Stats"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Tetris.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="20" Height="350" Width="180" BorderBrush="{DynamicResource TetrisGreen}" BorderThickness="2">

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource PanelLightBackground}"/>

                <Style.Triggers>
                    <DataTrigger
  Binding="{Binding DarkMode,
                    RelativeSource={RelativeSource AncestorType=local:Stats}}"
  Value="True">
                        <Setter Property="Background" Value="{DynamicResource PanelDarkBackground}"/>
                    </DataTrigger>
                </Style.Triggers>

            </Style>
        </Border.Style>

        
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,10,0,0">
                    <Image Source="/Images/Icons/Score.png" Width="32" Height="32"></Image>
                    <TextBlock VerticalAlignment="Center" Text="SCORE" Margin="5,0,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
                </StackPanel>
                <TextBlock Text="12,300" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" FontStyle="Normal"></TextBlock>
            </StackPanel>
            <Border Width="120"
            Height="2"
            Background="Gray"
            Margin="0,10,0,0"/>
            <StackPanel Orientation="Vertical" Margin="0,5,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,10,0,0">
                    <Image Source="/Images/Icons/Level.png" Width="32" Height="32"></Image>
                    <TextBlock VerticalAlignment="Center" Text="LEVEL" Margin="5,0,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
                </StackPanel>
                <TextBlock Text="7" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" FontStyle="Normal"></TextBlock>
            </StackPanel>
            <Border Width="120"
            Height="2"
            Background="Gray"
            Margin="0,10,0,0"/>
            <StackPanel Orientation="Vertical" Margin="0,5,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,10,0,0">
                    <Image Source="/Images/Icons/Lines.png" Width="32" Height="32"></Image>
                    <TextBlock VerticalAlignment="Center" Text="LINES" Margin="5,0,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
                </StackPanel>
                <TextBlock Text="42" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="26" FontStyle="Normal"></TextBlock>
            </StackPanel>
        </StackPanel>
        
        
    </Border>
</UserControl>
