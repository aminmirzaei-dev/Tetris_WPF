<UserControl x:Class="Tetris.Panels.Stats"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Tetris.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="20" Height="200" Width="150" Background="White" BorderBrush="#fc0339" BorderThickness="2">
        <StackPanel Orientation="Vertical">
            <TextBlock Text="NEXT" HorizontalAlignment="Left" Margin="10,10,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
            <Border VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0" Background="DodgerBlue" Height="100" Width="50"></Border>
        </StackPanel>
    </Border>
</UserControl>
