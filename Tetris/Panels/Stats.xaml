<UserControl x:Class="Tetris.Panels.Stats"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Tetris.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="20" Height="300" Width="150" Background="White" BorderBrush="#fc0339" BorderThickness="2">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="SCORE" HorizontalAlignment="Left" Margin="10,10,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
                <TextBlock Text="12,300" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,10,0,0" FontSize="26" FontStyle="Normal"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Text="LEVEL" HorizontalAlignment="Left" Margin="10,10,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
                <TextBlock Text="7" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,10,0,0" FontSize="26" FontStyle="Normal"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Text="LINES" HorizontalAlignment="Left" Margin="10,10,0,0" FontSize="16" FontStyle="Normal"></TextBlock>
                <TextBlock Text="42" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,10,0,0" FontSize="26" FontStyle="Normal"></TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
