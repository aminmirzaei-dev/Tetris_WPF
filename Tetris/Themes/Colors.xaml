<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="LightWindowBackground" Color="White"/>
    <SolidColorBrush x:Key="DarkWindowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="LightPanelBackground" Color="WhiteSmoke"/>
    <SolidColorBrush x:Key="DarkPanelBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="WindowLightBorderColor" Color="Black"/>
    <SolidColorBrush x:Key="WindowDarkBorderColor" Color="White"/>
    <SolidColorBrush x:Key="WindowLightTitleBackground" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="WindowDarkTitleBackground" Color="#252526"/>
    <SolidColorBrush x:Key="PanelBorderColor" Color="SlateBlue"/>

</ResourceDictionary>