<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Tetris.Controls">


    <Style TargetType="{x:Type local:SplashProgressBar}">
        <Setter Property="Height" Value="12"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SplashProgressBar}">

                    <Border
                    Background="#23262E"
                    CornerRadius="5"
                    BorderBrush="#2F3440"
                    BorderThickness="0">

                        <Grid Margin="1">

                            <!-- Progress -->
                            <Border
                            x:Name="PART_Progress"
                            Width="{Binding ProgressWidth,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                            HorizontalAlignment="Left"
                            CornerRadius="4">

                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">

                                        <GradientStop Color="#5B8CFF"
                                                  Offset="0"/>

                                        <GradientStop Color="#6BDBFF"
                                                  Offset="1"/>

                                    </LinearGradientBrush>
                                </Border.Background>

                            </Border>

                            <!-- Shine -->
                            <Border
                            Width="{Binding ProgressWidth,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                            HorizontalAlignment="Left"
                            CornerRadius="4"
                            IsHitTestVisible="False"
                            Opacity="0.15">

                                <Border.Background>
                                    <LinearGradientBrush
                                    StartPoint="0,0"
                                    EndPoint="0,1">

                                        <GradientStop
                                        Color="White"
                                        Offset="0"/>

                                        <GradientStop
                                        Color="Transparent"
                                        Offset="1"/>

                                    </LinearGradientBrush>
                                </Border.Background>

                            </Border>

                        </Grid>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsReversed"
                             Value="True">

                            <Setter
                            TargetName="PART_Progress"
                            Property="HorizontalAlignment"
                            Value="Right"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:CaptionButton}">

        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="42"/>

        <Setter Property="Background" Value="#252526"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="Foreground" Value="White"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="{x:Type local:CaptionButton}">

                    <Grid>

                        <!-- Background -->
                        <Border x:Name="Border"
                            CornerRadius="999"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                                >

                            <Border.Effect>

                                <DropShadowEffect x:Name="Shadow"
                  Color="#66000000"
                  BlurRadius="0"
                  ShadowDepth="0"
                  Opacity="0"/>

                            </Border.Effect>

                        </Border>

                        <!-- Icon -->
                        <Grid x:Name="IconContainer"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          RenderTransformOrigin="0.5,0.5">

                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="IconScale"
                            ScaleX="1"
                            ScaleY="1"/>
                            </Grid.RenderTransform>

                            <TextBlock Text="{TemplateBinding Icon}"
                   FontFamily="Segoe Fluent Icons"
                   FontSize="{TemplateBinding IconSize}"
                   Foreground="{TemplateBinding Foreground}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

                        </Grid>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="DarkMode"
                     Value="True">

                            <Setter TargetName="Border"
                        Property="Background"
                        Value="#3b3b3b"/>

                            <Setter Property="Foreground"
                        Value="#fcfcfc"/>

                        </Trigger>

                        <Trigger Property="DarkMode"
        Value="False">

                            <Setter TargetName="Border"
Property="Background"
Value="White"/>

                            <Setter Property="Foreground"
Value="Black"/>

                        </Trigger>


                        <Trigger Property="Mode" Value="Close">
                            <Setter Property="Icon" Value=""/>
                        </Trigger>

                        <Trigger Property="Mode" Value="Maximize">
                            <Setter Property="Icon" Value=""/>
                        </Trigger>

                        <Trigger Property="Mode" Value="Minimize">
                            <Setter Property="Icon" Value=""/>
                        </Trigger>

                        <Trigger Property="Mode" Value="Restore">
                            <Setter Property="Icon" Value=""/>
                        </Trigger>



                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">

                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>

                                        <DoubleAnimation Storyboard.TargetName="IconScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1.15"
                                                     Duration="0:0:0.15"/>

                                        <DoubleAnimation Storyboard.TargetName="IconScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1.15"
                                                     Duration="0:0:0.15"/>

                                        <!-- Shadow نرم و هماهنگ با رنگ -->
                                        <DoubleAnimation Storyboard.TargetName="Shadow"
                 Storyboard.TargetProperty="BlurRadius"
                 To="22"
                 Duration="0:0:0.15"/>

                                        <DoubleAnimation Storyboard.TargetName="Shadow"
                 Storyboard.TargetProperty="Opacity"
                 To="0.35"
                 Duration="0:0:0.15"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>

                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>

                                        <DoubleAnimation Storyboard.TargetName="IconScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1"
                                                     Duration="0:0:0.15"/>

                                        <DoubleAnimation Storyboard.TargetName="IconScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1"
                                                     Duration="0:0:0.15"/>

                                        <DoubleAnimation Storyboard.TargetName="Shadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="0"
                                                     Duration="0:0:0.15"/>

                                        <DoubleAnimation Storyboard.TargetName="Shadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.15"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>

                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border"
                                Property="Opacity"
                                Value="0.85"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>

    <Style TargetType="{x:Type local:GameButton}">

        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="{x:Type local:GameButton}">

                    <Grid x:Name="Root"
                      RenderTransformOrigin="0.5,0.5">

                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1"
                                        ScaleY="1"/>
                        </Grid.RenderTransform>

                        <!-- Shadow -->
                        <Border Margin="0,4,0,0"
                            CornerRadius="14"
                            Background="#22000000"/>

                        <!-- Main Body -->
                        <Border x:Name="MainBorder"
                            CornerRadius="14"
                            BorderThickness="3">

                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="0,1">

                                    <!--<GradientStop Color="#4EFF68"
                                              Offset="0"/>

                                    <GradientStop Color="#20D945"
                                              Offset="0.5"/>

                                    <GradientStop Color="#0DBA32"
                                              Offset="1"/>-->

                                    <GradientStop Color="{Binding TopBrush.Color,
    RelativeSource={RelativeSource TemplatedParent}}"
    Offset="0"/>

                                    <GradientStop Color="{Binding Background.Color,
    RelativeSource={RelativeSource TemplatedParent}}"
    Offset="0.5"/>

                                    <GradientStop Color="{Binding BottomBrush.Color,
    RelativeSource={RelativeSource TemplatedParent}}"
    Offset="1"/>

                                </LinearGradientBrush>
                            </Border.Background>

                        </Border>

                        <!-- Inner Border -->
                        <Border Margin="5"
                            CornerRadius="10"
                            BorderThickness="1"
                            BorderBrush="#55FFFFFF"/>

                        <!-- Top Highlight -->
                        <Border Margin="6"
                            Height="22"
                            VerticalAlignment="Top"
                            CornerRadius="10">

                            <Border.Background>

                                <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="0,1">

                                    <GradientStop Color="#AAFFFFFF"
                                              Offset="0"/>

                                    <GradientStop Color="#00FFFFFF"
                                              Offset="1"/>

                                </LinearGradientBrush>

                            </Border.Background>

                        </Border>

                        <!-- Shine -->
                        <Border x:Name="Shine"
                            Margin="6"
                            CornerRadius="10"
                            Opacity="0">

                            <Border.Background>

                                <LinearGradientBrush StartPoint="-1,0"
                                                 EndPoint="1,0">

                                    <GradientStop Color="#00FFFFFF"
                                              Offset="0"/>

                                    <GradientStop Color="#88FFFFFF"
                                              Offset="0.5"/>

                                    <GradientStop Color="#00FFFFFF"
                                              Offset="1"/>

                                </LinearGradientBrush>

                            </Border.Background>

                        </Border>

                        <!-- Content -->
                        <Grid Margin="20,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <TextBlock Grid.Column="0"
                                   Text="{TemplateBinding Icon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="{TemplateBinding IconSize}"
                                   Foreground="{TemplateBinding Foreground}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,15,0"/>

                            <!-- Text -->
                            <ContentPresenter Grid.Column="1"
                                          Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>

                        </Grid>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver"
                             Value="True">

                            <Trigger.EnterActions>

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                        To="1.03"
                                        Duration="0:0:0.15"/>

                                        <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                        To="1.03"
                                        Duration="0:0:0.15"/>

                                        <DoubleAnimation
                                        Storyboard.TargetName="Shine"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0.8"
                                        Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </Trigger.EnterActions>

                            <Trigger.ExitActions>

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                        To="1"
                                        Duration="0:0:0.15"/>

                                        <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                        To="1"
                                        Duration="0:0:0.15"/>

                                        <DoubleAnimation
                                        Storyboard.TargetName="Shine"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0"
                                        Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </Trigger.ExitActions>

                        </Trigger>

                        <Trigger Property="IsPressed"
         Value="True">

                            <Setter TargetName="MainBorder"
            Property="Opacity"
            Value="0.9"/>

                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled"
                             Value="False">

                            <Setter Property="Opacity"
                                Value="0.5"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>

    <Style TargetType="{x:Type local:BaseWindow}">

        <Setter Property="BorderBrush" Value="#404040"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="AllowsTransparency" Value="True"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="{x:Type local:BaseWindow}">

                    <Border x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Title Bar -->

                            <Border x:Name="TitleBar"
                                Grid.Row="0"
                                CornerRadius="12,12,0,0" >

                                <DockPanel LastChildFill="True">

                                        <!-- Icon + Title -->

                                    <Grid Margin="10,0">

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left side: Icon + Title -->
                                        <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center">

                                            <Image Width="18"
               Height="18"
               Source="{TemplateBinding Icon}"/>

                                            <TextBlock Text="{TemplateBinding Title}"
                   Margin="4,0,0,0"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <!-- Right side: Buttons -->
                                        <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center">

                                            <local:CaptionButton x:Name="CloseButton"
            Width="25"
            Height="25"
            Mode="Close"
            VerticalAlignment="Center"
            IconSize="10"
            Margin="0,0,5,0"
            DarkMode="{TemplateBinding DarkMode}"/>
                                        </StackPanel>

                                    </Grid>
                                </DockPanel>

                            </Border>

                            <!-- Content -->

                            <Border Grid.Row="1"
                                Background="{TemplateBinding Background}">

                                <AdornerDecorator>
                                    <ContentPresenter/>
                                </AdornerDecorator>

                            </Border>

                        </Grid>

                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Dark Mode -->

                        <Trigger Property="DarkMode"
                             Value="True">

                            <Setter TargetName="RootBorder"
                                Property="Background"
                                Value="#1E1E1E"/>

                            <Setter TargetName="TitleBar"
                                Property="Background"
                                Value="#252526"/>

                            <Setter Property="Foreground"
                                Value="White"/>

                        </Trigger>

                        <!-- Light Mode -->

                        <Trigger Property="DarkMode"
                             Value="False">

                            <Setter TargetName="RootBorder"
                                Property="Background"
                                Value="White"/>

                            <Setter TargetName="TitleBar"
                                Property="Background"
                                Value="#F3F4F6"/>

                            <Setter Property="Foreground"
                                Value="Black"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>
</ResourceDictionary>
