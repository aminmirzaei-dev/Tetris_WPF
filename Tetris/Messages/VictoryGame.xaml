<base:BaseWindow x:Class="Tetris.Messages.VictoryGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tetris.Messages"
        xmlns:base="clr-namespace:Tetris.Controls"
        mc:Ignorable="d"
                 WindowMode="Dialog"
                 DarkMode="True"
                 Icon="/Images/Logo/TetrisLogo.png"
                 WindowStartupLocation="CenterOwner"
        Title=" Victory Game" Height="300" Width="500">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Image Margin="0,20,0,0" Width="100" Height="100" Source="/Images/Icons/Victory.png"></Image>
            <TextBlock VerticalAlignment="Center" Margin="0,10,0,0" HorizontalAlignment="Center" FontSize="30" Foreground="Gold" Text="You Victory Is This Game !"></TextBlock>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,30,0,0">
                <base:GameButton Icon="" IconSize="14" Margin="0,0,5,0" Background="DodgerBlue" Content="Restart" Width="150" Height="50"></base:GameButton>
                <base:GameButton Icon="" IconSize="14" Margin="0,0,10,0" Background="Green" Content="Ok" Width="100" Height="50"></base:GameButton>
            </StackPanel>
        </StackPanel>
    </Grid>
</base:BaseWindow>
