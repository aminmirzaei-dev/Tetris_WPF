<base:BaseWindow x:Class="Tetris.Messages.ExitGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tetris.Messages"
        xmlns:base="clr-namespace:Tetris.Controls"
        mc:Ignorable="d"
                 WindowMode="Dialog"
                 WindowStartupLocation="CenterOwner"
                 DarkMode="True"
                 Icon="/Images/Logo/TetrisLogo.png"
        Title=" Exit Game" Height="320" Width="600">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Image Margin="0,20,0,0" Width="100" Height="100" Source="/Images/Icons/Exit.png"></Image>
            <TextBlock VerticalAlignment="Center" Margin="0,10,0,0" HorizontalAlignment="Center" FontSize="30" Foreground="Crimson" Text="Are you sure you want to exit the game ?"></TextBlock>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,50,0,0">
                <base:GameButton Click="CancelButton_Click" Icon="" IconSize="14" Margin="0,0,5,0" Background="DodgerBlue" Content="Cancel" Width="150" Height="50"></base:GameButton>
                <base:GameButton Click="YetButton_Click" Icon="" IconSize="14" Margin="0,0,10,0" Background="Tomato" Content="Yes" Width="100" Height="50"></base:GameButton>
            </StackPanel>
        </StackPanel>
    </Grid>
</base:BaseWindow>
